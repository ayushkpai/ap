#!/usr/bin/env ruby

require "open3"

print "What is the app name?\n> "
app = gets&.strip

if app.nil? || app.empty?
  puts "❌ App name cannot be empty."
  exit 1
end

print "\nDo you want to use Tailwind CSS? [Y/n] "
use_tailwind = gets&.strip.to_s.downcase

command =
  case use_tailwind
  when "", "y", "yes"
    ["rails", "new", app, "--css", "tailwind"]
  when "n", "no"
    ["rails", "new", app]
  else
    puts "❌ Invalid choice. Please enter Y or N."
    exit 1
  end

puts "\nAbout to run:"
puts "  #{command.join(' ')}"

print "\nContinue? [Y/n] "
confirm = gets&.strip.to_s.downcase

unless ["", "y", "yes"].include?(confirm)
  puts "Cancelled."
  exit
end

print "\n🚀 Creating Rails app..."
success = system(*command, out: File::NULL, err: File::NULL)
puts success ? " ✅" : " ❌"

unless success
  puts "Failed to create the Rails app."
  exit 1
end

puts "✅ Rails app '#{app}' created successfully."

Dir.chdir(app) do
  print "\n📦 Staging files..."
  success = system("git", "add", ".", out: File::NULL, err: File::NULL)
  puts success ? " ✅" : " ❌"

  unless success
    puts "git add failed."
    exit 1
  end

  print "📝 Creating initial commit..."
  success = system(
    "git",
    "commit",
    "-m",
    "Initial commit By Rail",
    out: File::NULL,
    err: File::NULL
  )
  puts success ? " ✅" : " ❌"

  unless success
    puts "git commit failed."
    exit 1
  end

  print "\nPush to GitHub? [y/N] "
  push = gets&.strip.to_s.downcase

  if ["y", "yes"].include?(push)
    has_remote = system(
      "git",
      "remote",
      "get-url",
      "origin",
      out: File::NULL,
      err: File::NULL
    )

    unless has_remote
      print "GitHub repository URL: "
      remote = gets&.strip

      if remote.nil? || remote.empty?
        puts "❌ No remote provided."
        exit 1
      end

      print "🔗 Adding remote..."
      success = system(
        "git",
        "remote",
        "add",
        "origin",
        remote,
        out: File::NULL,
        err: File::NULL
      )
      puts success ? " ✅" : " ❌"

      unless success
        puts "Failed to add remote."
        exit 1
      end
    end

    branch = `git branch --show-current`.strip
    branch = "main" if branch.empty?

    print "⬆️  Pushing to GitHub..."
    success = system(
      "git",
      "push",
      "-u",
      "origin",
      branch,
      out: File::NULL,
      err: File::NULL
    )
    puts success ? " ✅" : " ❌"

    unless success
      puts "Push failed."
    end
  end

  print "\nRun the project now? [Y/n] "
  run = gets&.strip.to_s.downcase

  if ["", "y", "yes"].include?(run)
    puts "\n🚀 Starting Rails..."

Open3.popen2e("bin/dev") do |_stdin, stdout, wait_thread|
  pid = wait_thread.pid
  started = false

  trap("INT") do
    puts "\n🛑 Stopping Rails..."
    Process.kill("INT", pid) rescue nil
  end

  stdout.each_line do |line|
    unless started
      if (url = line[%r{https?://\S+}])
        puts "✅ Started on #{url}"
        started = true
      end
    end
  end

  wait_thread.value
end
  end
end

puts "\n🎉 All done!"
